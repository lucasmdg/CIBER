# --- Core ---
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-byte-random-secret

# --- Database ---
# Default to a local SQLite file for the portfolio demo.
# Swap to Postgres for production: postgresql://user:pass@host:5432/sentinelx
DATABASE_URL="file:./dev.db"

# --- Security Posture Scanner ---
# Restrict scanning to loopback / private ranges. Never widen in production demos.
POSTURE_ALLOW_CIDRS="127.0.0.1/32,::1/128,10.0.0.0/8,192.168.0.0/16"

# --- Audit & rate limiting ---
AUDIT_LOG_RETENTION_DAYS=90
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
