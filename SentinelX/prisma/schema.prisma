// SentinelX Prisma schema
// Default: SQLite for portfolio/demo. Swap provider to "postgresql" for prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("viewer")
  passwordHash  String?
  createdAt     DateTime  @default(now())
  sessions      Session[]
  accounts      Account[]
  auditEvents   AuditLog[] @relation("actorEvents")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Asset {
  id           String   @id @default(cuid())
  name         String   @unique
  ip           String
  os           String
  owner        String
  type         String
  criticality  String
  riskScore    Int      @default(0)
  createdAt    DateTime @default(now())
  findings     Finding[]
}

model Vulnerability {
  id           String   @id @default(cuid())
  cve          String   @unique
  title        String
  severity     String
  cvss         Float
  status       String   @default("open")
  description  String
  published    DateTime
  affected     Finding[]
  createdAt    DateTime @default(now())
}

model Finding {
  id              String        @id @default(cuid())
  assetId         String
  vulnerabilityId String
  notes           String?
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vulnerability   Vulnerability @relation(fields: [vulnerabilityId], references: [id], onDelete: Cascade)
  @@unique([assetId, vulnerabilityId])
}

model ThreatActor {
  id          String   @id @default(cuid())
  name        String   @unique
  origin      String
  motivation  String
  aliases     String
  ttps        String
  mitre       String
  summary     String
  createdAt   DateTime @default(now())
}

model Malware {
  id        String   @id @default(cuid())
  family    String   @unique
  type      String
  ttps      String
  campaign  String
  firstSeen DateTime
}

model PostureCheck {
  id        String   @id @default(cuid())
  target    String
  category  String
  name      String
  status    String   // pass | warn | fail
  detail    String
  evidence  String?
  createdAt DateTime @default(now())
}

model AttackPath {
  id        String   @id @default(cuid())
  name      String
  scenario  String
  steps     String   // JSON encoded
  createdAt DateTime @default(now())
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  severity    String
  phase       String
  summary     String
  events      IncidentEvent[]
  createdAt   DateTime @default(now())
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  phase      String
  title      String
  description String
  ts         DateTime @default(now())
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String?
  meta      String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation("actorEvents", fields: [userId], references: [id], onDelete: SetNull)
}

model FileAnalysis {
  id                String   @id @default(cuid())
  filename          String
  sha256            String
  md5               String
  fileType          String
  sizeBytes         Int
  entropy           Float
  verdict           String   // clean | suspicious | likely_malicious
  score             Int
  suspiciousStrings String   // JSON string list
  createdAt         DateTime @default(now())
}

model ExternalCache {
  key       String   @id
  data      String   // JSON stringified payload
  updatedAt DateTime @default(now())
}
